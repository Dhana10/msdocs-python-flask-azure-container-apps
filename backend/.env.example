# Copy to .env for local development (not used in Azure Container Apps).

##### Production (Azure) — set in Container App / Key Vault references
# RUNNING_IN_PRODUCTION=1
# DBHOST=<postgres-server-short-name>
# DBNAME=restaurants_reviews
# DBUSER=<managed-identity-name>
# AZURE_CLIENT_ID=<managed-identity-client-id>
# AZURE_SECRET_KEY=<flask-secret>
# APP_ALLOWED_HOSTS=<container-app-fqdn>
# CORS_ORIGINS=https://<swa-host>.azurestaticapps.net

##### Local development
# LOCAL_SECRET_KEY=change-me
# DBHOST=localhost
# DBNAME=restaurants_reviews
# DBUSER=postgres
# DBPASS=your-password

##### Local app connecting to Azure PostgreSQL with service principal
# USE_REMOTE_POSTGRESQL=1
# DBHOST=<server-short-name>
# DBNAME=restaurants_reviews
# DBUSER=<sp-name>
# AZURE_CLIENT_ID=
# AZURE_TENANT_ID=
# AZURE_CLIENT_SECRET=
